{
  "manifest_version": 3,
  "name": "AnimeIntroSkipper",
  "version": "1.1.0",
  "description": "Keyboard shortcut to skip the Anime Intro.",
  "permissions": ["scripting", "activeTab"],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "commands": {
    "skip-forward-90": {
      "suggested_key": {
        "default": "Alt+Shift+Period",
        "mac": "Option+Shift+Period"
      },
      "description": "Skip video forward 90 seconds"
    },
    "skip-backward-90": {
      "suggested_key": {
        "default": "Alt+Shift+Comma",
        "mac": "Option+Shift+Comma"
      },
      "description": "Skip video backward 90 seconds"
    }
  }
}
